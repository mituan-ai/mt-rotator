DJANGO_SECRET_KEY=replace-with-at-least-50-random-characters-generated-securely
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=https://localhost
DJANGO_SECURE_COOKIES=true
DJANGO_SECURE_SSL_REDIRECT=true
DJANGO_HSTS_SECONDS=0
DJANGO_HSTS_PRELOAD=false
PUBLIC_BASE_URL=https://localhost
SITE_ADDRESS=localhost
DATABASE_URL=postgresql://mt_rotator:mt_rotator@postgres:5432/mt_rotator
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CACHE_URL=redis://redis:6379/2
POSTGRES_DB=mt_rotator
POSTGRES_USER=mt_rotator
POSTGRES_PASSWORD=replace-with-a-strong-password
BACKUP_DIR=./backups
