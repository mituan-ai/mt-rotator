DJANGO_SECRET_KEY=ci-only-secret-key-with-more-than-50-characters-not-for-production
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1,http://localhost
DJANGO_SECURE_COOKIES=false
DJANGO_SECURE_SSL_REDIRECT=false
DJANGO_HSTS_SECONDS=0
DJANGO_HSTS_PRELOAD=false
PUBLIC_BASE_URL=http://127.0.0.1
SITE_ADDRESS=:80
CADDY_HEALTH_URL=http://localhost/api/v1/health/live
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CACHE_URL=redis://redis:6379/2
POSTGRES_DB=mt_rotator
POSTGRES_USER=mt_rotator
POSTGRES_PASSWORD=ci-only-database-password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
BACKUP_DIR=./backups
